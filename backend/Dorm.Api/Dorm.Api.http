@Dorm.Api_HostAddress = http://localhost:5265
@StudentEmail = student1@ius.edu.ba
@StudentPassword = Student123!
@AuthToken = replace_with_token
@StaffAuthToken = replace_with_staff_token
@RequestId = 00000000-0000-0000-0000-000000000000
@StaffUserId = 00000000-0000-0000-0000-000000000000

### Register (Student)
POST {{Dorm.Api_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "fullName": "Student One",
  "email": "{{StudentEmail}}",
  "password": "{{StudentPassword}}",
  "role": 0,
  "dormRoom": "A-203",
  "phoneNumber": "+38761000111"
}

###

### Login
POST {{Dorm.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{StudentEmail}}",
  "password": "{{StudentPassword}}"
}

###

### Example protected endpoint test template
### Replace /api/your-protected-route when available
GET {{Dorm.Api_HostAddress}}/api/your-protected-route
Accept: application/json
Authorization: Bearer {{AuthToken}}

###

### Create Maintenance Request (Student)
POST {{Dorm.Api_HostAddress}}/api/maintenance-requests
Content-Type: application/json
Authorization: Bearer {{AuthToken}}

{
  "title": "Water leakage in bathroom",
  "description": "The sink pipe is leaking and floor gets wet.",
  "location": "Dorm A - Room 203",
  "priority": 2,
  "categoryId": "00000000-0000-0000-0000-000000000000"
}

###

### Get My Maintenance Requests (Student)
GET {{Dorm.Api_HostAddress}}/api/maintenance-requests/my
Accept: application/json
Authorization: Bearer {{AuthToken}}

###

### Update My Maintenance Request (Student)
PUT {{Dorm.Api_HostAddress}}/api/maintenance-requests/{{RequestId}}
Content-Type: application/json
Authorization: Bearer {{AuthToken}}

{
  "title": "Water leakage in bathroom (updated)",
  "description": "Leak is worse; please prioritize.",
  "location": "Dorm A - Room 203",
  "priority": 2,
  "categoryId": "00000000-0000-0000-0000-000000000000"
}

###

### Delete My Maintenance Request (Student)
DELETE {{Dorm.Api_HostAddress}}/api/maintenance-requests/{{RequestId}}
Authorization: Bearer {{AuthToken}}

###

### List All Maintenance Requests (MaintenanceStaff or Admin)
GET {{Dorm.Api_HostAddress}}/api/maintenance-requests
Accept: application/json
Authorization: Bearer {{StaffAuthToken}}

###

### Update Request Status (MaintenanceStaff or Admin)
PATCH {{Dorm.Api_HostAddress}}/api/maintenance-requests/{{RequestId}}/status
Content-Type: application/json
Authorization: Bearer {{StaffAuthToken}}

{
  "status": 1,
  "assignedStaffId": "{{StaffUserId}}"
}

###
